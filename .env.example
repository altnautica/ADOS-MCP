# ADOS MCP environment. Copy to .env for local runs. No secret is committed.

# Log verbosity: debug | info | warn | error
ADOS_MCP_LOG_LEVEL=info

# --- Agent-mode (local-first, default) ---
# One drone on the LAN, no cloud. The drone's pairing key, sent as X-ADOS-Key
# (or read from /etc/ados/pairing.json on the drone itself).
# ADOS_MCP_AGENT_KEY=
# The agent host to reach. Defaults to 127.0.0.1.
# ADOS_AGENT_HOST=
# This node's device id.
# ADOS_NODE_ID=
# The Streamable HTTP port. Defaults to 8091.
# ADOS_MCP_HTTP_PORT=8091

# --- Local-fleet mode (many LAN drones, no cloud) ---
# Path to the fleet file the Mission Control MCP tab exports (each drone's host +
# pairing key). Defaults to ~/.ados/mcp/fleet.json.
# ADOS_MCP_FLEET_PATH=

# --- Fleet-mode (cloud, opt-in) ---
# The operator machine credential minted in the Mission Control MCP tab.
# ADOS_MCP_TOKEN=
# The Mission Control Convex backend url (local or prod; --gcs is the shortcut).
# ADOS_CONVEX_URL=
# The MQTT broker URL for live streams.
# ADOS_MQTT_URL=

# --- Development only ---
# A local dev secret enabling the 'local' token issuer for bench and CI. Never
# set this on a real deployment.
# ADOS_MCP_LOCAL_SECRET=
