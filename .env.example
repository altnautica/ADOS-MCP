# ADOS MCP environment. Copy to .env for local runs. No secret is committed.

# Log verbosity: debug | info | warn | error
ADOS_MCP_LOG_LEVEL=info

# --- Agent-mode ---
# The bearer token minted in the Mission Control MCP tab (stdio launch principal).
# ADOS_MCP_TOKEN=
# The agent host to reach (agent-mode). Defaults to 127.0.0.1.
# ADOS_AGENT_HOST=
# This node's device id (agent-mode).
# ADOS_NODE_ID=
# The Streamable HTTP port in agent-mode. Defaults to 8091.
# ADOS_MCP_HTTP_PORT=8091

# --- Fleet-mode ---
# The Convex deployment URL for the fleet backend.
# ADOS_CONVEX_URL=
# The MQTT broker URL for live streams.
# ADOS_MQTT_URL=
# The hosted endpoint name shown in connect recipes.
# ADOS_MCP_FLEET_ENDPOINT=https://mcp.altnautica.com/mcp

# --- Development only ---
# A local dev secret enabling the 'local' token issuer for bench and CI. Never
# set this on a real deployment.
# ADOS_MCP_LOCAL_SECRET=
